# Environment Configuration
# Copy to .env and fill in your values

# PostgreSQL
POSTGRES_PASSWORD=your_secure_password

# Directus
DIRECTUS_SECRET=your-directus-secret-key
DIRECTUS_ADMIN_PASSWORD=your-admin-password

# WeChat Mini Program
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Ollama (Local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_LLAMA8B=llama3.1:8b
OLLAMA_MODEL_LLAMA70B=llama3.1:70b
OLLAMA_MODEL_WHISPER=whisper-large-v3
OLLAMA_MODEL_EMBEDDING=bge-m3

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333

# Valkey (Redis)
VALKEY_URL=redis://localhost:6379

# Directus API
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=your-directus-static-token

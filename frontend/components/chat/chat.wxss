.chat-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background-color: var(--color-gray-50);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 20rpx) var(--space-4) var(--space-4);
  background: linear-gradient(135deg, #1E3A8A 0%, #1E40AF 50%, #3B82F6 100%);
  color: var(--color-white);
  box-shadow: 0 4rpx 16rpx rgba(44, 95, 138, 0.35);
  position: relative;
}

.chat-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 0.3;
}

.header-left {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.ai-avatar {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0.1) 100%);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(8rpx);
}

.ai-avatar-icon {
  font-size: 44rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
}

.header-status {
  font-size: var(--font-size-xs);
  opacity: 0.85;
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.header-status::before {
  content: '';
  width: 12rpx;
  height: 12rpx;
  background: var(--color-success-light);
  border-radius: var(--radius-full);
  box-shadow: 0 0 8rpx rgba(72, 187, 120, 0.6);
}

.header-close {
  font-size: 64rpx;
  color: rgba(255, 255, 255, 0.85);
  padding: 0 var(--space-2);
  position: relative;
  z-index: 1;
  line-height: 1;
}

.header-close:active {
  color: rgba(255, 255, 255, 0.6);
}

.chat-messages {
  flex: 1;
  padding: var(--space-4);
  overflow-y: auto;
  background: linear-gradient(180deg, var(--color-gray-50) 0%, #f8fafc 100%);
}

.messages-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  padding-bottom: var(--space-8);
}

.message-item {
  display: flex;
  gap: var(--space-3);
  animation: fadeIn 0.3s ease-out;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, var(--color-gray-200) 0%, var(--color-gray-300) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid var(--color-white);
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.1);
}

.message-avatar.user {
  background: var(--color-secondary-gradient);
  border-color: rgba(255, 255, 255, 0.3);
}

.avatar-icon {
  font-size: 36rpx;
}

.message-content-wrapper {
  max-width: 75%;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.message-bubble {
  padding: var(--space-4) var(--space-5);
  border-radius: var(--radius-xl);
  background-color: var(--color-white);
  box-shadow: 0 4rpx 12rpx rgba(26, 54, 93, 0.08);
  position: relative;
}

.message-bubble::before {
  content: '';
  position: absolute;
  top: 20rpx;
  width: 0;
  height: 0;
  border: 12rpx solid transparent;
}

.message-item.user .message-bubble {
  background: var(--color-primary-gradient);
  color: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 4rpx var(--radius-xl);
}

.message-item.user .message-bubble::before {
  right: -20rpx;
  border-left-color: var(--color-primary);
}

.message-item:not(.user) .message-bubble {
  border-radius: var(--radius-xl) var(--radius-xl) var(--radius-xl) 4rpx;
}

.message-item:not(.user) .message-bubble::before {
  left: -20rpx;
  border-right-color: var(--color-white);
}

.message-bubble.typing {
  background-color: var(--color-gray-100);
  padding: var(--space-4) var(--space-6);
}

.typing-dots {
  animation: blink 1.2s infinite;
  color: var(--color-gray-400);
  font-weight: var(--font-weight-bold);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.message-text {
  font-size: var(--font-size-base);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.message-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-2);
}

.suggestion-chip {
  padding: var(--space-2) var(--space-4);
  background: linear-gradient(135deg, var(--color-gray-100) 0%, var(--color-gray-50) 100%);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  transition: all var(--transition-fast);
  border: 1rpx solid var(--color-gray-200);
}

.suggestion-chip:active {
  background: var(--color-primary-gradient);
  color: var(--color-white);
  border-color: var(--color-primary);
  transform: scale(0.95);
}

.message-action {
  display: flex;
  margin-top: var(--space-2);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  background: linear-gradient(135deg, rgba(43, 108, 176, 0.1) 0%, rgba(66, 153, 225, 0.1) 100%);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
  border: 1rpx solid rgba(43, 108, 176, 0.15);
}

.action-btn:active {
  background: var(--color-secondary-gradient);
}

.action-icon {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.action-text {
  font-size: var(--font-size-xs);
  color: var(--color-secondary);
  font-weight: var(--font-weight-medium);
}

.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  padding: var(--space-4);
  background: linear-gradient(180deg, var(--color-white) 0%, rgba(247, 250, 252, 0.95) 100%);
  border-top: 1rpx solid var(--color-gray-100);
}

.quick-reply {
  padding: var(--space-2) var(--space-4);
  background: linear-gradient(135deg, var(--color-gray-100) 0%, var(--color-gray-50) 100%);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  transition: all var(--transition-fast);
  border: 1rpx solid var(--color-gray-200);
}

.quick-reply:active {
  background: var(--color-primary-gradient);
  color: var(--color-white);
  border-color: var(--color-primary);
  transform: scale(0.95);
}

.chat-input-bar {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(255,255,255,1) 100%);
  border-top: 1rpx solid var(--color-gray-100);
  backdrop-filter: blur(10rpx);
}

.voice-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--color-gray-100) 0%, var(--color-gray-200) 100%);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all var(--transition-fast);
  border: 2rpx solid var(--color-gray-200);
}

.voice-btn:active {
  background: var(--color-error-gradient);
  border-color: var(--color-error);
}

.voice-btn.recording {
  background: var(--color-error-gradient);
  border-color: var(--color-error);
  box-shadow: 0 4rpx 16rpx rgba(229, 62, 62, 0.3);
}

.voice-icon {
  font-size: 40rpx;
}

.recording-indicator {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: var(--color-error);
  border-radius: var(--radius-full);
  padding: 6rpx 12rpx;
  min-width: 52rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(229, 62, 62, 0.4);
}

.recording-time {
  font-size: var(--font-size-xs);
  color: var(--color-white);
  font-weight: var(--font-weight-bold);
}

.input-wrapper {
  flex: 1;
}

.chat-input {
  width: 100%;
  padding: var(--space-4) var(--space-5);
  background: linear-gradient(135deg, var(--color-gray-100) 0%, #e8ecf1 100%);
  border-radius: var(--radius-full);
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.chat-input:focus {
  background: var(--color-white);
  border-color: var(--color-secondary);
  box-shadow: 0 2rpx 8rpx rgba(43, 108, 176, 0.15);
}

.chat-input::placeholder {
  color: var(--color-gray-400);
}

.send-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--color-gray-200) 0%, var(--color-gray-300) 100%);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  border: 2rpx solid var(--color-gray-200);
}

.send-btn.active {
  background: var(--color-secondary-gradient);
  border-color: var(--color-secondary);
  box-shadow: 0 4rpx 16rpx rgba(43, 108, 176, 0.35);
}

.send-icon {
  font-size: 40rpx;
  color: var(--color-gray-500);
  font-weight: bold;
}

.send-btn.active .send-icon {
  color: var(--color-white);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

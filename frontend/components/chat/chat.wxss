.chat-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background-color: var(--color-gray-50);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 20rpx) var(--space-4) var(--space-3);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: var(--color-white);
}

.header-left {
  display: flex;
  align-items: center;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3);
}

.ai-avatar-icon {
  font-size: 40rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
}

.header-status {
  font-size: var(--font-size-xs);
  opacity: 0.8;
}

.header-close {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 0 var(--space-2);
}

.chat-messages {
  flex: 1;
  padding: var(--space-4);
  overflow-y: auto;
}

.messages-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding-bottom: var(--space-8);
}

.message-item {
  display: flex;
  gap: var(--space-2);
  animation: fadeIn 0.3s ease-out;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-gray-200);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.message-avatar.user {
  background-color: var(--color-secondary);
}

.avatar-icon {
  font-size: 32rpx;
}

.message-content-wrapper {
  max-width: 70%;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.message-bubble {
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-lg);
  background-color: var(--color-white);
  box-shadow: var(--shadow-sm);
}

.message-item.user .message-bubble {
  background-color: var(--color-primary);
  color: var(--color-white);
}

.message-bubble.typing {
  background-color: var(--color-gray-100);
}

.typing-dots {
  animation: blink 1s infinite;
  color: var(--color-gray-400);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.message-text {
  font-size: var(--font-size-base);
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
  word-break: break-word;
}

.message-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.suggestion-chip {
  padding: var(--space-2) var(--space-3);
  background-color: var(--color-gray-100);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  transition: all var(--transition-fast);
}

.suggestion-chip:active {
  background-color: var(--color-primary);
  color: var(--color-white);
}

.message-action {
  display: flex;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  background-color: rgba(43, 108, 176, 0.1);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.action-btn:active {
  background-color: rgba(43, 108, 176, 0.2);
}

.action-icon {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.action-text {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-4);
  background-color: var(--color-white);
  border-top: 1rpx solid var(--color-gray-100);
}

.quick-reply {
  padding: var(--space-2) var(--space-3);
  background-color: var(--color-gray-50);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  transition: all var(--transition-fast);
}

.quick-reply:active {
  background-color: var(--color-primary);
  color: var(--color-white);
}

.chat-input-bar {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-4);
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
  background-color: var(--color-white);
  border-top: 1rpx solid var(--color-gray-100);
}

.voice-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: var(--color-gray-100);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all var(--transition-fast);
}

.voice-btn:active {
  background-color: var(--color-gray-200);
}

.voice-btn.recording {
  background-color: var(--color-error);
}

.voice-icon {
  font-size: 36rpx;
}

.recording-indicator {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: var(--color-error);
  border-radius: var(--radius-full);
  padding: 4rpx 8rpx;
  min-width: 48rpx;
  text-align: center;
}

.recording-time {
  font-size: var(--font-size-xs);
  color: var(--color-white);
  font-weight: var(--font-weight-medium);
}

.input-wrapper {
  flex: 1;
}

.chat-input {
  width: 100%;
  padding: var(--space-3) var(--space-4);
  background-color: var(--color-gray-100);
  border-radius: var(--radius-full);
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
}

.chat-input::placeholder {
  color: var(--color-gray-400);
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: var(--color-gray-200);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.send-btn.active {
  background-color: var(--color-primary);
}

.send-icon {
  font-size: 36rpx;
  color: var(--color-gray-500);
}

.send-btn.active .send-icon {
  color: var(--color-white);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
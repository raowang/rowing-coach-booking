.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
}

.tabs {
  display: flex;
  background-color: var(--color-white);
  padding: 0 var(--space-4);
  border-bottom: 1rpx solid var(--color-gray-100);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3) 0;
  position: relative;
}

.tab-name {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  transition: color var(--transition-fast);
}

.tab-item.active .tab-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-full);
}

.bookings-content {
  padding: var(--space-4);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) 0;
}

.loading-text {
  margin-top: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.bookings-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.booking-card {
  background-color: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.booking-header {
  display: flex;
  padding: var(--space-4);
  active: opacity(0.8);
}

.booking-date-badge {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.date-day {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-white);
  line-height: 1;
}

.date-month {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.8);
}

.booking-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.booking-coach {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.booking-time {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  margin-bottom: var(--space-1);
}

.booking-status {
  font-size: var(--font-size-xs);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  display: inline-block;
  width: fit-content;
}

.status-pending {
  background-color: rgba(214, 158, 46, 0.1);
  color: var(--color-warning);
}

.status-confirmed {
  background-color: rgba(56, 161, 105, 0.1);
  color: var(--color-success);
}

.status-in_progress {
  background-color: rgba(49, 130, 206, 0.1);
  color: var(--color-info);
}

.status-completed {
  background-color: rgba(56, 161, 105, 0.1);
  color: var(--color-success);
}

.status-cancelled {
  background-color: rgba(229, 62, 62, 0.1);
  color: var(--color-error);
}

.booking-actions {
  display: flex;
  border-top: 1rpx solid var(--color-gray-100);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3);
  gap: var(--space-1);
  transition: background-color var(--transition-fast);
}

.action-btn:active {
  background-color: var(--color-gray-50);
}

.action-btn:not(:last-child) {
  border-right: 1rpx solid var(--color-gray-100);
}

.action-btn.cancel {
  color: var(--color-error);
}

.action-icon {
  font-size: var(--font-size-base);
}

.action-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
}

.action-btn.cancel .action-text {
  color: var(--color-error);
}

.booking-footer {
  padding: var(--space-3) var(--space-4);
  background-color: var(--color-gray-50);
  border-top: 1rpx solid var(--color-gray-100);
}

.feedback-preview {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.feedback-label {
  color: var(--color-gray-500);
}

.feedback-text {
  color: var(--color-gray-700);
}

.view-feedback {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.view-feedback-text {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.view-feedback-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-secondary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  text-align: center;
}

.mt-4 {
  margin-top: var(--space-4);
}

.cancel-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-index-modal);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background-color: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4);
  border-bottom: 1rpx solid var(--color-gray-100);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
}

.modal-close {
  font-size: 48rpx;
  color: var(--color-gray-400);
  padding: 0 var(--space-2);
}

.modal-body {
  padding: var(--space-4);
  max-height: 60vh;
  overflow-y: auto;
}

.cancel-booking-info {
  background-color: var(--color-gray-50);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  margin-bottom: var(--space-4);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-1) 0;
}

.info-label {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.info-value {
  font-size: var(--font-size-sm);
  color: var(--color-gray-800);
  font-weight: var(--font-weight-medium);
}

.cancel-reason-section {
  margin-bottom: var(--space-4);
}

.reason-label {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.reason-input {
  width: 100%;
  min-height: 160rpx;
  padding: var(--space-3);
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
  background-color: var(--color-gray-50);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.cancel-notice {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  padding: var(--space-3);
  background-color: rgba(214, 158, 46, 0.1);
  border-radius: var(--radius-md);
}

.notice-icon {
  font-size: var(--font-size-base);
}

.notice-text {
  flex: 1;
  font-size: var(--font-size-xs);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.modal-footer {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  border-top: 1rpx solid var(--color-gray-100);
}

.modal-footer .btn {
  flex: 1;
}

.btn-danger {
  background-color: var(--color-error);
  color: var(--color-white);
}
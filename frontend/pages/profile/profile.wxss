.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
  padding-bottom: var(--space-8);
}

.profile-header {
  position: relative;
  background: linear-gradient(135deg, #1E3A8A 0%, #1E40AF 50%, #3B82F6 100%);
  padding: calc(env(safe-area-inset-top) + 24rpx) var(--space-4) 100rpx;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.profile-header::after {
  content: '';
  position: absolute;
  bottom: -40%;
  left: -15%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  pointer-events: none;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 0.4;
}

.header-content {
  position: relative;
}

.profile-info {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-5);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-full);
  border: 5rpx solid rgba(255, 255, 255, 0.5);
  margin-right: var(--space-4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
}

.info-text {
  flex: 1;
}

.name {
  font-size: 44rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-white);
  margin-bottom: var(--space-1);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.member-type {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  display: inline-block;
}

.edit-btn {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.edit-icon {
  font-size: var(--font-size-lg);
}

.membership-card {
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: 0 8rpx 24rpx rgba(44, 95, 138, 0.18);
}

.membership-status {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: var(--radius-full);
  margin-right: var(--space-2);
}

.membership-status.active .status-dot {
  background-color: var(--color-success);
  box-shadow: 0 0 8rpx rgba(46, 204, 113, 0.6);
}

.membership-status.expiring .status-dot {
  background-color: var(--color-warning);
  box-shadow: 0 0 8rpx rgba(244, 208, 63, 0.6);
}

.membership-status.expired .status-dot {
  background-color: var(--color-error);
  box-shadow: 0 0 8rpx rgba(231, 76, 60, 0.6);
}

.status-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  font-weight: var(--font-weight-semibold);
}

.membership-detail {
  border-top: 1rpx solid var(--color-gray-100);
  padding-top: var(--space-3);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.detail-label {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.detail-value {
  font-size: var(--font-size-sm);
  color: var(--color-gray-800);
  font-weight: var(--font-weight-semibold);
}

.detail-value.highlight {
  color: var(--color-primary);
}

.renew-hint {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-3);
  padding: var(--space-3) var(--space-3);
  background: linear-gradient(135deg, rgba(237, 137, 54, 0.1) 0%, rgba(246, 173, 85, 0.08) 100%);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--color-accent);
}

.hint-icon {
  font-size: var(--font-size-base);
}

.hint-text {
  font-size: var(--font-size-xs);
  color: var(--color-accent);
  font-weight: var(--font-weight-medium);
}

.stats-section {
  margin: calc(-1 * var(--space-8)) var(--space-4) 0;
  position: relative;
  z-index: 1;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-2);
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: 0 6rpx 20rpx rgba(44, 95, 138, 0.14);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1rpx;
  background: var(--color-gray-200);
}

.stat-value {
  font-size: 44rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  margin-bottom: var(--space-1);
  line-height: 1;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
  text-align: center;
}

.achievements-section,
.recent-section {
  margin: var(--space-4);
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: 0 4rpx 16rpx rgba(44, 95, 138, 0.1);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
}

.section-more {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  font-weight: var(--font-weight-semibold);
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
}

.achievement-item {
  background: linear-gradient(180deg, var(--color-gray-50) 0%, rgba(237, 242, 247, 0.5) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  position: relative;
  transition: all var(--transition-fast);
  border: 1rpx solid var(--color-gray-100);
}

.achievement-item.locked {
  opacity: 0.5;
}

.achievement-item.unlocked {
  background: linear-gradient(135deg, rgba(26, 54, 93, 0.05) 0%, rgba(43, 108, 176, 0.05) 100%);
  border: 1rpx solid rgba(26, 54, 93, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(26, 54, 93, 0.08);
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: var(--space-2);
}

.achievement-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.achievement-desc {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.achievement-progress {
  margin-top: var(--space-3);
}

.progress-bar {
  height: 10rpx;
  background-color: var(--color-gray-200);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-full);
  transition: width var(--transition-normal);
}

.progress-text {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
  margin-top: var(--space-1);
  display: block;
}

.achievement-unlocked {
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
}

.unlocked-icon {
  font-size: var(--font-size-base);
  color: var(--color-success);
}

.menu-section {
  margin: var(--space-4);
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 54, 93, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  border-bottom: 1rpx solid var(--color-gray-100);
  transition: background-color var(--transition-fast);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--color-gray-50);
}

.menu-icon {
  font-size: var(--font-size-xl);
  margin-right: var(--space-4);
}

.menu-text {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
  font-weight: var(--font-weight-medium);
}

.menu-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-gray-400);
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.recent-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background: linear-gradient(135deg, var(--color-gray-50) 0%, rgba(247, 250, 252, 0.5) 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-gray-100);
}

.recent-date {
  width: 80rpx;
  text-align: center;
  margin-right: var(--space-3);
}

.recent-day {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
  display: block;
  line-height: 1.2;
}

.recent-month {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.recent-info {
  flex: 1;
}

.recent-coach {
  font-size: var(--font-size-sm);
  color: var(--color-gray-800);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--space-1);
}

.recent-duration {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.recent-rating {
  display: flex;
  align-items: center;
  background: rgba(214, 158, 46, 0.1);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
}

.star {
  color: var(--color-warning);
  font-size: var(--font-size-sm);
}

.rating {
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  margin-left: var(--space-1);
  font-weight: var(--font-weight-semibold);
}

.logout-section {
  margin: var(--space-6) var(--space-4);
}

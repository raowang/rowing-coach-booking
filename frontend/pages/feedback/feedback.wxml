<view class="page">
  <view class="tabs">
    <view
      class="tab-item {{selectedTab === item.id ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="id"
      data-tab-id="{{item.id}}"
      bindtap="onTabChange"
    >
      <text class="tab-name">{{item.name}}</text>
      <view class="tab-indicator" wx:if="{{selectedTab === item.id}}"></view>
    </view>
  </view>

  <view class="tab-content">
    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="spinner large"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="detail-view" wx:if="{{selectedTab === 'detail' && feedback && !isLoading}}">
      <view class="feedback-card">
        <view class="card-header">
          <image
            class="coach-avatar"
            src="{{feedback.coachAvatarUrl || '/assets/images/default-coach.png'}}"
            mode="aspectFill"
          ></image>
          <view class="coach-info">
            <view class="coach-name">{{feedback.coachName}}</view>
            <view class="training-date">{{feedback.date}} {{feedback.timeSlot}}</view>
          </view>
          <view class="rating-badge">
            <text class="rating-value">{{feedback.rating}}</text>
            <text class="rating-label">评分</text>
          </view>
        </view>

        <view class="card-body">
          <view class="section">
            <view class="section-title">教练点评</view>
            <view class="comment-box">
              <text class="comment-text">{{feedback.comment || '暂无点评'}}</text>
            </view>
          </view>

          <view class="section" wx:if="{{feedback.strengths && feedback.strengths.length > 0}}">
            <view class="section-title">表现优点</view>
            <view class="tags-list">
              <view
                class="tag-item strength"
                wx:for="{{feedback.strengths}}"
                wx:key="index"
              >
                <text class="tag-icon">✓</text>
                <text class="tag-text">{{item}}</text>
              </view>
            </view>
          </view>

          <view class="section" wx:if="{{feedback.areasForImprovement && feedback.areasForImprovement.length > 0}}">
            <view class="section-title">需改进</view>
            <view class="tags-list">
              <view
                class="tag-item improvement"
                wx:for="{{feedback.areasForImprovement}}"
                wx:key="index"
              >
                <text class="tag-icon">→</text>
                <text class="tag-text">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="ai-suggestions-card" wx:if="{{aiSuggestions.length > 0}}">
        <view class="card-header">
          <view class="ai-badge">
            <text class="ai-icon">🤖</text>
            <text class="ai-title">AI改善建议</text>
          </view>
        </view>
        <view class="suggestions-list">
          <view
            class="suggestion-item"
            wx:for="{{aiSuggestions}}"
            wx:key="index"
          >
            <view class="suggestion-number">{{index + 1}}</view>
            <view class="suggestion-content">
              <view class="suggestion-title">{{item.title}}</view>
              <view class="suggestion-desc">{{item.description}}</view>
              <view class="suggestion-action" wx:if="{{item.action}}">
                <text class="action-hint">{{item.action}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="action-section">
        <button class="btn btn-primary btn-block" bindtap="onBookAgain">
          <text class="btn-icon">📅</text>
          再次预约
        </button>
      </view>

      <view class="next-training-hint" wx:if="{{feedback.suggestedNextTraining}}">
        <view class="hint-icon">💡</view>
        <view class="hint-content">
          <view class="hint-title">AI推荐下次训练时间</view>
          <view class="hint-text">{{feedback.suggestedNextTraining}}</view>
        </view>
      </view>
    </view>

    <view class="history-view" wx:if="{{selectedTab === 'history' && !isLoading}}">
      <view class="history-list" wx:if="{{history.length > 0}}">
        <view
          class="history-item"
          wx:for="{{history}}"
          wx:key="id"
          data-booking-id="{{item.id}}"
          bindtap="onHistoryItemTap"
        >
          <view class="history-date">
            <text class="date-day">{{item.dateDay}}</text>
            <text class="date-month">{{item.dateMonth}}月</text>
          </view>
          <view class="history-info">
            <view class="history-coach">{{item.coachName}}</view>
            <view class="history-rating" wx:if="{{item.rating}}">
              <text class="star">★</text>
              <text class="rating">{{item.rating}}</text>
            </view>
            <view class="history-comment" wx:if="{{item.feedback}}">{{item.feedback}}</view>
          </view>
          <view class="history-arrow">›</view>
        </view>
      </view>

      <view class="empty-state" wx:elif="{{!isLoading}}">
        <text class="empty-icon">📝</text>
        <text class="empty-title">暂无反馈记录</text>
        <text class="empty-desc">完成训练后，教练的点评将显示在这里</text>
      </view>
    </view>

    <view class="no-feedback" wx:if="{{selectedTab === 'detail' && !feedback && !isLoading}}">
      <view class="empty-state">
        <text class="empty-icon">📋</text>
        <text class="empty-title">暂无反馈</text>
        <text class="empty-desc">完成训练后即可查看教练点评和AI建议</text>
        <button class="btn btn-primary mt-4" bindtap="onViewSchedule">查看日程</button>
      </view>
    </view>
  </view>
</view>
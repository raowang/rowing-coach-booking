.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
}

.tabs {
  display: flex;
  background-color: var(--color-white);
  padding: 0 var(--space-4);
  border-bottom: 1rpx solid var(--color-gray-100);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-4) 0;
  position: relative;
}

.tab-name {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  font-weight: var(--font-weight-medium);
  transition: color var(--transition-fast);
}

.tab-item.active .tab-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 56rpx;
  height: 5rpx;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-full);
}

.tab-content {
  padding: var(--space-4);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) 0;
}

.loading-text {
  margin-top: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.feedback-card {
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 54, 93, 0.08);
  margin-bottom: var(--space-4);
  border: 1rpx solid var(--color-gray-100);
}

.card-header {
  display: flex;
  align-items: center;
  padding: var(--space-5);
  background: linear-gradient(135deg, #1E3A8A 0%, #1E40AF 50%, #3B82F6 100%);
  color: var(--color-white);
}

.coach-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-full);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: var(--space-4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
}

.coach-info {
  flex: 1;
}

.coach-name {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  margin-bottom: var(--space-1);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.training-date {
  font-size: var(--font-size-sm);
  opacity: 0.9;
}

.rating-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  backdrop-filter: blur(8rpx);
}

.rating-value {
  font-size: 52rpx;
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

.rating-label {
  font-size: var(--font-size-xs);
  opacity: 0.85;
  margin-top: 4rpx;
}

.card-body {
  padding: var(--space-5);
}

.section {
  margin-bottom: var(--space-5);
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-500);
  margin-bottom: var(--space-3);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.comment-box {
  background: linear-gradient(135deg, var(--color-gray-50) 0%, rgba(237, 242, 247, 0.5) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  border: 1rpx solid var(--color-gray-100);
}

.comment-text {
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
  line-height: 1.7;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.tag-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

.tag-item.strength {
  background: linear-gradient(135deg, rgba(56, 161, 105, 0.12) 0%, rgba(72, 187, 120, 0.08) 100%);
  color: var(--color-success);
  border: 1rpx solid rgba(56, 161, 105, 0.2);
}

.tag-item.improvement {
  background: linear-gradient(135deg, rgba(214, 158, 46, 0.12) 0%, rgba(236, 201, 75, 0.08) 100%);
  color: var(--color-warning);
  border: 1rpx solid rgba(214, 158, 46, 0.2);
}

.tag-icon {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
}

.tag-text {
  font-size: var(--font-size-sm);
}

.ai-suggestions-card {
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 54, 93, 0.08);
  margin-bottom: var(--space-4);
  border: 1rpx solid var(--color-gray-100);
}

.ai-badge {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4);
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(167, 139, 250, 0.05) 100%);
  border-bottom: 1rpx solid rgba(139, 92, 246, 0.1);
}

.ai-icon {
  font-size: 40rpx;
}

.ai-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: #7c3aed;
}

.suggestions-list {
  padding: var(--space-4);
}

.suggestion-item {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  background: linear-gradient(135deg, var(--color-gray-50) 0%, rgba(247, 250, 252, 0.5) 100%);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-3);
  border: 1rpx solid var(--color-gray-100);
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-number {
  width: 52rpx;
  height: 52rpx;
  background: var(--color-secondary-gradient);
  color: var(--color-white);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(43, 108, 176, 0.3);
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.suggestion-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: 1.6;
}

.suggestion-action {
  margin-top: var(--space-2);
}

.action-hint {
  font-size: var(--font-size-xs);
  color: var(--color-secondary);
  font-style: italic;
  font-weight: var(--font-weight-medium);
}

.action-section {
  margin-bottom: var(--space-4);
}

.btn-icon {
  margin-right: var(--space-2);
}

.next-training-hint {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-4);
  background: linear-gradient(135deg, rgba(49, 130, 206, 0.08) 0%, rgba(66, 153, 225, 0.05) 100%);
  border-radius: var(--radius-lg);
  border-left: 5rpx solid var(--color-secondary);
}

.hint-icon {
  font-size: 40rpx;
}

.hint-content {
  flex: 1;
}

.hint-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  font-weight: var(--font-weight-medium);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.history-item {
  display: flex;
  align-items: center;
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: 0 4rpx 16rpx rgba(26, 54, 93, 0.08);
  transition: all var(--transition-fast);
  border: 1rpx solid var(--color-gray-100);
}

.history-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.1);
}

.history-date {
  width: 88rpx;
  text-align: center;
  margin-right: var(--space-4);
}

.date-day {
  font-size: 44rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  display: block;
  line-height: 1.2;
}

.date-month {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.history-info {
  flex: 1;
}

.history-coach {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.history-rating {
  display: inline-flex;
  align-items: center;
  background: rgba(214, 158, 46, 0.1);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-1);
}

.star {
  color: var(--color-warning);
  font-size: var(--font-size-sm);
}

.rating {
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  margin-left: var(--space-1);
  font-weight: var(--font-weight-semibold);
}

.history-comment {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.history-arrow {
  font-size: 44rpx;
  color: var(--color-gray-400);
  margin-left: var(--space-2);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  text-align: center;
  line-height: 1.6;
}

.mt-4 {
  margin-top: var(--space-4);
}

.no-feedback {
  padding: var(--space-4);
}

.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
}

.tabs {
  display: flex;
  background-color: var(--color-white);
  padding: 0 var(--space-4);
  border-bottom: 1rpx solid var(--color-gray-100);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3) 0;
  position: relative;
}

.tab-name {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  transition: color var(--transition-fast);
}

.tab-item.active .tab-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-full);
}

.tab-content {
  padding: var(--space-4);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) 0;
}

.loading-text {
  margin-top: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.feedback-card {
  background-color: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-4);
}

.card-header {
  display: flex;
  align-items: center;
  padding: var(--space-4);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: var(--color-white);
}

.coach-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-full);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  margin-right: var(--space-3);
}

.coach-info {
  flex: 1;
}

.coach-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--space-1);
}

.training-date {
  font-size: var(--font-size-sm);
  opacity: 0.9;
}

.rating-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-md);
  padding: var(--space-2) var(--space-3);
}

.rating-value {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

.rating-label {
  font-size: var(--font-size-xs);
  opacity: 0.8;
}

.card-body {
  padding: var(--space-4);
}

.section {
  margin-bottom: var(--space-4);
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-gray-500);
  margin-bottom: var(--space-2);
}

.comment-box {
  background-color: var(--color-gray-50);
  border-radius: var(--radius-md);
  padding: var(--space-3);
}

.comment-text {
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
  line-height: var(--line-height-relaxed);
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.tag-item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
}

.tag-item.strength {
  background-color: rgba(56, 161, 105, 0.1);
  color: var(--color-success);
}

.tag-item.improvement {
  background-color: rgba(214, 158, 46, 0.1);
  color: var(--color-warning);
}

.tag-icon {
  font-size: var(--font-size-xs);
}

.tag-text {
  font-size: var(--font-size-sm);
}

.ai-suggestions-card {
  background-color: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-4);
}

.ai-badge {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-4);
  background-color: rgba(139, 92, 246, 0.05);
  border-bottom: 1rpx solid var(--color-gray-100);
}

.ai-icon {
  font-size: var(--font-size-lg);
}

.ai-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: #7c3aed;
}

.suggestions-list {
  padding: var(--space-3);
}

.suggestion-item {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-3);
  background-color: var(--color-gray-50);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-2);
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-primary) 100%);
  color: var(--color-white);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.suggestion-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.suggestion-action {
  margin-top: var(--space-2);
}

.action-hint {
  font-size: var(--font-size-xs);
  color: var(--color-secondary);
  font-style: italic;
}

.action-section {
  margin-bottom: var(--space-4);
}

.btn-icon {
  margin-right: var(--space-2);
}

.next-training-hint {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-3);
  background-color: rgba(49, 130, 206, 0.05);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--color-secondary);
}

.hint-icon {
  font-size: 32rpx;
}

.hint-content {
  flex: 1;
}

.hint-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.history-item {
  display: flex;
  align-items: center;
  background-color: var(--color-white);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.history-item:active {
  transform: scale(0.98);
}

.history-date {
  width: 80rpx;
  text-align: center;
  margin-right: var(--space-3);
}

.date-day {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  display: block;
}

.date-month {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.history-info {
  flex: 1;
}

.history-coach {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.history-rating {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-1);
}

.star {
  color: var(--color-warning);
  font-size: var(--font-size-sm);
}

.rating {
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  margin-left: var(--space-1);
}

.history-comment {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.history-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-gray-400);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  text-align: center;
}

.mt-4 {
  margin-top: var(--space-4);
}

.no-feedback {
  padding: var(--space-4);
}
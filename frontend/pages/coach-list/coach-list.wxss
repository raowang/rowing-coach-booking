.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
  padding-bottom: var(--space-4);
}

.search-bar {
  padding: var(--space-4);
  background-color: var(--color-white);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(44, 95, 138, 0.08);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--color-gray-100) 0%, #E2E8F0 100%);
  border-radius: var(--radius-full);
  padding: var(--space-3) var(--space-4);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.search-input-wrapper:focus-within {
  border-color: var(--color-accent);
  background: var(--color-white);
}

.search-icon {
  font-size: var(--font-size-base);
  margin-right: var(--space-2);
}

.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
}

.search-input::placeholder {
  color: var(--color-gray-400);
}

.filter-bar {
  background-color: var(--color-white);
  padding: var(--space-3) 0;
  border-bottom: 1rpx solid var(--color-gray-200);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 var(--space-4);
  gap: var(--space-2);
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  background-color: var(--color-gray-100);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.filter-item.active {
  background: var(--color-accent-gradient);
  color: var(--color-white);
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 28, 0.3);
}

.filter-icon {
  font-size: var(--font-size-sm);
  margin-right: var(--space-1);
}

.filter-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: inherit;
}

.recommended-section {
  background-color: var(--color-white);
  padding: var(--space-4);
  margin-bottom: var(--space-2);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
}

.ai-badge {
  display: flex;
  align-items: center;
  padding: var(--space-1) var(--space-3);
  background: linear-gradient(135deg, rgba(44, 95, 138, 0.1) 0%, rgba(74, 144, 217, 0.1) 100%);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(44, 95, 138, 0.15);
}

.ai-icon {
  font-size: var(--font-size-sm);
  margin-right: var(--space-1);
}

.ai-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.recommended-scroll {
  white-space: nowrap;
}

.recommended-row {
  display: inline-flex;
  gap: var(--space-3);
}

.recommended-item {
  width: 300rpx;
  background: linear-gradient(135deg, #1E3A8A 0%, #1E40AF 50%, #3B82F6 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  position: relative;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(1, 87, 155, 0.35);
}

.recommended-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Ccircle cx='20' cy='20' r='15'/%3E%3C/g%3E%3C/svg%3E");
  border-radius: var(--radius-xl);
  pointer-events: none;
}

.recommended-badge {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  font-size: var(--font-size-xs);
  padding: var(--space-1) var(--space-3);
  background: var(--color-accent-gradient);
  color: var(--color-white);
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-semibold);
  box-shadow: 0 2rpx 8rpx rgba(255, 159, 28, 0.4);
}

.recommended-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-full);
  margin-bottom: var(--space-3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.recommended-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-white);
  margin-bottom: var(--space-2);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.recommended-reason {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: var(--space-3);
  line-height: var(--line-height-relaxed);
}

.recommended-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
}

.recommended-tag {
  font-size: var(--font-size-xs);
  padding: 4rpx var(--space-2);
  background-color: rgba(255, 255, 255, 0.25);
  color: var(--color-white);
  border-radius: var(--radius-full);
  backdrop-filter: blur(4rpx);
}

.coach-list {
  padding: var(--space-4);
}

.list-header {
  margin-bottom: var(--space-3);
}

.list-count {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  font-weight: var(--font-weight-medium);
}

.coach-items {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.coach-card {
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: 0 4rpx 16rpx rgba(44, 95, 138, 0.1);
  transition: all var(--transition-fast);
  border: 1rpx solid var(--color-gray-200);
}

.coach-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(44, 95, 138, 0.12);
  border-color: var(--color-accent);
}

.coach-main {
  display: flex;
  margin-bottom: var(--space-3);
}

.coach-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--radius-lg);
  margin-right: var(--space-4);
  flex-shrink: 0;
  border: 3rpx solid var(--color-gray-200);
  box-shadow: 0 4rpx 12rpx rgba(44, 95, 138, 0.12);
}

.coach-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coach-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.coach-name {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
}

.coach-status {
  font-size: var(--font-size-xs);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-semibold);
}

.coach-status.available {
  background: linear-gradient(135deg, rgba(46, 204, 113, 0.15) 0%, rgba(88, 214, 141, 0.15) 100%);
  color: var(--color-success);
  border: 1rpx solid rgba(46, 204, 113, 0.25);
}

.coach-status.busy {
  background: linear-gradient(135deg, rgba(231, 76, 60, 0.15) 0%, rgba(236, 112, 99, 0.15) 100%);
  color: var(--color-error);
  border: 1rpx solid rgba(231, 76, 60, 0.25);
}

.coach-title {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  margin-bottom: var(--space-2);
}

.coach-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}

.coach-tag {
  font-size: var(--font-size-xs);
  padding: 4rpx var(--space-2);
  background-color: var(--color-gray-100);
  color: var(--color-gray-600);
  border-radius: var(--radius-full);
}

.coach-stats {
  display: flex;
  gap: var(--space-5);
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.coach-description {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
  margin-bottom: var(--space-3);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.coach-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--color-gray-100);
}

.action-text {
  font-size: var(--font-size-sm);
  color: var(--color-accent);
  font-weight: var(--font-weight-semibold);
}

.action-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-accent);
  margin-left: var(--space-1);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4);
  gap: var(--space-2);
}

.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.no-more {
  text-align: center;
  padding: var(--space-4);
  font-size: var(--font-size-sm);
  color: var(--color-gray-400);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: var(--z-index-modal);
  backdrop-filter: blur(10rpx);
}

.spinner.large {
  width: 72rpx;
  height: 72rpx;
  border-width: 6rpx;
  border-color: var(--color-gray-200);
  border-top-color: var(--color-accent);
}

.recommendation-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-index-modal);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4rpx);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 85vh;
  background-color: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5);
  border-bottom: 1rpx solid var(--color-gray-100);
  background: linear-gradient(180deg, var(--color-gray-50) 0%, var(--color-white) 100%);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
}

.modal-close {
  font-size: 56rpx;
  color: var(--color-gray-400);
  padding: 0 var(--space-2);
  line-height: 1;
}

.modal-close:active {
  color: var(--color-gray-600);
}

.modal-body {
  padding: var(--space-5);
  max-height: 65vh;
  overflow-y: auto;
}

.rec-coach-info {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-5);
  padding: var(--space-4);
  background: linear-gradient(135deg, var(--color-gray-50) 0%, var(--color-white) 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-gray-100);
}

.rec-coach-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  margin-right: var(--space-4);
  border: 4rpx solid var(--color-white);
  box-shadow: 0 4rpx 16rpx rgba(44, 95, 138, 0.2);
}

.rec-coach-details {
  flex: 1;
}

.rec-coach-name {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.rec-coach-title {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.rec-reason-section {
  margin-bottom: var(--space-5);
}

.rec-reason-title,
.rec-insight-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-700);
  margin-bottom: var(--space-3);
}

.rec-reason-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.rec-reason-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
}

.rec-reason-icon {
  color: var(--color-success);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
}

.rec-reason-text {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.rec-ai-insight {
  background: linear-gradient(135deg, rgba(44, 95, 138, 0.08) 0%, rgba(74, 144, 217, 0.05) 100%);
  padding: var(--space-4);
  border-radius: var(--radius-lg);
  border-left: 5rpx solid var(--color-accent);
}

.rec-insight-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.modal-footer {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-gray-100);
  background: var(--color-white);
}

.modal-footer .btn {
  flex: 1;
}
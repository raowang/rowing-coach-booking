.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
  padding-bottom: var(--space-4);
}

.search-bar {
  padding: var(--space-3) var(--space-4);
  background-color: var(--color-white);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: var(--color-gray-100);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4);
}

.search-icon {
  font-size: var(--font-size-base);
  margin-right: var(--space-2);
}

.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
}

.search-input::placeholder {
  color: var(--color-gray-400);
}

.filter-bar {
  background-color: var(--color-white);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--color-gray-100);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 var(--space-4);
  gap: var(--space-2);
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-3);
  background-color: var(--color-gray-100);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.filter-item.active {
  background-color: var(--color-primary);
  color: var(--color-white);
}

.filter-icon {
  font-size: var(--font-size-sm);
  margin-right: var(--space-1);
}

.filter-name {
  font-size: var(--font-size-sm);
  color: inherit;
}

.recommended-section {
  background-color: var(--color-white);
  padding: var(--space-4);
  margin-bottom: var(--space-2);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
}

.ai-badge {
  display: flex;
  align-items: center;
  padding: var(--space-1) var(--space-2);
  background-color: rgba(139, 92, 246, 0.1);
  border-radius: var(--radius-full);
}

.ai-icon {
  font-size: var(--font-size-sm);
  margin-right: var(--space-1);
}

.ai-text {
  font-size: var(--font-size-xs);
  color: #7c3aed;
}

.recommended-scroll {
  white-space: nowrap;
}

.recommended-row {
  display: inline-flex;
  gap: var(--space-3);
}

.recommended-item {
  width: 280rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  position: relative;
  flex-shrink: 0;
}

.recommended-badge {
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
  font-size: var(--font-size-xs);
  padding: var(--space-1) var(--space-2);
  background-color: var(--color-accent);
  color: var(--color-white);
  border-radius: var(--radius-full);
}

.recommended-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-full);
  margin-bottom: var(--space-2);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.recommended-name {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-white);
  margin-bottom: var(--space-1);
}

.recommended-reason {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: var(--space-2);
  line-height: var(--line-height-relaxed);
}

.recommended-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
}

.recommended-tag {
  font-size: var(--font-size-xs);
  padding: 2rpx var(--space-2);
  background-color: rgba(255, 255, 255, 0.2);
  color: var(--color-white);
  border-radius: var(--radius-full);
}

.coach-list {
  padding: var(--space-4);
}

.list-header {
  margin-bottom: var(--space-3);
}

.list-count {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.coach-items {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.coach-card {
  background-color: var(--color-white);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.coach-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.coach-main {
  display: flex;
  margin-bottom: var(--space-3);
}

.coach-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.coach-info {
  flex: 1;
  min-width: 0;
}

.coach-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-1);
}

.coach-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
}

.coach-status {
  font-size: var(--font-size-xs);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
}

.coach-status.available {
  background-color: rgba(56, 161, 105, 0.1);
  color: var(--color-success);
}

.coach-status.busy {
  background-color: rgba(229, 62, 62, 0.1);
  color: var(--color-error);
}

.coach-title {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  margin-bottom: var(--space-2);
}

.coach-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}

.coach-tag {
  font-size: var(--font-size-xs);
  padding: 2rpx var(--space-2);
  background-color: var(--color-gray-100);
  color: var(--color-gray-600);
  border-radius: var(--radius-full);
}

.coach-stats {
  display: flex;
  gap: var(--space-4);
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-gray-500);
}

.coach-description {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
  margin-bottom: var(--space-3);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.coach-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--color-gray-100);
}

.action-text {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  font-weight: var(--font-weight-medium);
}

.action-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-secondary);
  margin-left: var(--space-1);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4);
  gap: var(--space-2);
}

.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.no-more {
  text-align: center;
  padding: var(--space-4);
  font-size: var(--font-size-sm);
  color: var(--color-gray-400);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: var(--z-index-modal);
}

.spinner.large {
  width: 60rpx;
  height: 60rpx;
  border-width: 6rpx;
}

.recommendation-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-index-modal);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background-color: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4);
  border-bottom: 1rpx solid var(--color-gray-100);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
}

.modal-close {
  font-size: 48rpx;
  color: var(--color-gray-400);
  padding: 0 var(--space-2);
}

.modal-body {
  padding: var(--space-4);
  max-height: 60vh;
  overflow-y: auto;
}

.rec-coach-info {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
}

.rec-coach-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-full);
  margin-right: var(--space-3);
}

.rec-coach-details {
  flex: 1;
}

.rec-coach-name {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.rec-coach-title {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.rec-reason-section {
  margin-bottom: var(--space-4);
}

.rec-reason-title,
.rec-insight-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-gray-700);
  margin-bottom: var(--space-2);
}

.rec-reason-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.rec-reason-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
}

.rec-reason-icon {
  color: var(--color-success);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
}

.rec-reason-text {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.rec-ai-insight {
  background-color: var(--color-gray-50);
  padding: var(--space-3);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--color-secondary);
}

.rec-insight-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.modal-footer {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  border-top: 1rpx solid var(--color-gray-100);
}

.modal-footer .btn {
  flex: 1;
}
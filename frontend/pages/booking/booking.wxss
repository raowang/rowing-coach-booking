.page {
  min-height: 100vh;
  background-color: var(--color-gray-50);
}

.tabs {
  display: flex;
  background-color: var(--color-white);
  padding: 0 var(--space-4);
  border-bottom: 1rpx solid var(--color-gray-100);
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-4) 0;
  position: relative;
}

.tab-name {
  font-size: var(--font-size-base);
  color: var(--color-gray-500);
  font-weight: var(--font-weight-medium);
  transition: color var(--transition-fast);
}

.tab-item.active .tab-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 56rpx;
  height: 5rpx;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.bookings-content {
  padding: var(--space-4);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) 0;
}

.loading-text {
  margin-top: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.bookings-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.booking-card {
  background-color: var(--color-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(26, 54, 93, 0.08);
  border: 1rpx solid var(--color-gray-100);
  transition: all var(--transition-fast);
}

.booking-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.1);
}

.booking-header {
  display: flex;
  padding: var(--space-4);
}

.booking-date-badge {
  width: 112rpx;
  height: 112rpx;
  background: var(--color-primary-gradient);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-4);
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(44, 95, 138, 0.3);
}

.date-day {
  font-size: 48rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-white);
  line-height: 1;
}

.date-month {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.85);
  margin-top: 2rpx;
}

.booking-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.booking-coach {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
  margin-bottom: var(--space-1);
}

.booking-time {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  margin-bottom: var(--space-2);
}

.booking-status {
  font-size: var(--font-size-xs);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  display: inline-block;
  width: fit-content;
  font-weight: var(--font-weight-semibold);
}

.status-pending {
  background: linear-gradient(135deg, rgba(214, 158, 46, 0.15) 0%, rgba(236, 201, 75, 0.15) 100%);
  color: var(--color-warning);
  border: 1rpx solid rgba(214, 158, 46, 0.2);
}

.status-confirmed {
  background: linear-gradient(135deg, rgba(56, 161, 105, 0.15) 0%, rgba(72, 187, 120, 0.15) 100%);
  color: var(--color-success);
  border: 1rpx solid rgba(56, 161, 105, 0.2);
}

.status-in_progress {
  background: linear-gradient(135deg, rgba(49, 130, 206, 0.15) 0%, rgba(66, 153, 225, 0.15) 100%);
  color: var(--color-info);
  border: 1rpx solid rgba(49, 130, 206, 0.2);
}

.status-completed {
  background: linear-gradient(135deg, rgba(56, 161, 105, 0.15) 0%, rgba(72, 187, 120, 0.15) 100%);
  color: var(--color-success);
  border: 1rpx solid rgba(56, 161, 105, 0.2);
}

.status-cancelled {
  background: linear-gradient(135deg, rgba(229, 62, 62, 0.15) 0%, rgba(252, 129, 129, 0.15) 100%);
  color: var(--color-error);
  border: 1rpx solid rgba(229, 62, 62, 0.2);
}

.booking-actions {
  display: flex;
  border-top: 1rpx solid var(--color-gray-100);
  background: linear-gradient(180deg, var(--color-gray-50) 0%, rgba(247, 250, 252, 0.5) 100%);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4);
  gap: var(--space-2);
  transition: background-color var(--transition-fast);
}

.action-btn:active {
  background-color: rgba(26, 54, 93, 0.05);
}

.action-btn:not(:last-child) {
  border-right: 1rpx solid var(--color-gray-100);
}

.action-btn.cancel {
  color: var(--color-error);
}

.action-btn.cancel:active {
  background-color: rgba(229, 62, 62, 0.05);
}

.action-icon {
  font-size: var(--font-size-lg);
}

.action-text {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  font-weight: var(--font-weight-medium);
}

.action-btn.cancel .action-text {
  color: var(--color-error);
}

.booking-footer {
  padding: var(--space-4);
  background: linear-gradient(180deg, var(--color-gray-50) 0%, rgba(237, 242, 247, 0.5) 100%);
  border-top: 1rpx solid var(--color-gray-100);
}

.feedback-preview {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.feedback-label {
  color: var(--color-gray-500);
  font-weight: var(--font-weight-medium);
}

.feedback-text {
  color: var(--color-gray-700);
}

.view-feedback {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.view-feedback-text {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  font-weight: var(--font-weight-semibold);
}

.view-feedback-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-secondary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-4);
}

.empty-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
  text-align: center;
}

.mt-4 {
  margin-top: var(--space-4);
}

.cancel-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: var(--z-index-modal);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4rpx);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background-color: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5);
  border-bottom: 1rpx solid var(--color-gray-100);
  background: linear-gradient(180deg, var(--color-gray-50) 0%, var(--color-white) 100%);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
}

.modal-close {
  font-size: 56rpx;
  color: var(--color-gray-400);
  padding: 0 var(--space-2);
  line-height: 1;
}

.modal-close:active {
  color: var(--color-gray-600);
}

.modal-body {
  padding: var(--space-5);
  max-height: 60vh;
  overflow-y: auto;
}

.cancel-booking-info {
  background: linear-gradient(135deg, var(--color-gray-50) 0%, var(--color-white) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  border: 1rpx solid var(--color-gray-100);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: var(--space-2) 0;
}

.info-label {
  font-size: var(--font-size-sm);
  color: var(--color-gray-500);
}

.info-value {
  font-size: var(--font-size-sm);
  color: var(--color-gray-800);
  font-weight: var(--font-weight-semibold);
}

.cancel-reason-section {
  margin-bottom: var(--space-4);
}

.reason-label {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
  margin-bottom: var(--space-2);
  font-weight: var(--font-weight-medium);
}

.reason-input {
  width: 100%;
  min-height: 180rpx;
  padding: var(--space-4);
  font-size: var(--font-size-base);
  color: var(--color-gray-800);
  background-color: var(--color-gray-50);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-gray-200);
  box-sizing: border-box;
  transition: border-color var(--transition-fast);
}

.reason-input:focus {
  border-color: var(--color-secondary);
}

.cancel-notice {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-4);
  background: linear-gradient(135deg, rgba(214, 158, 46, 0.1) 0%, rgba(236, 201, 75, 0.08) 100%);
  border-radius: var(--radius-lg);
  border-left: 5rpx solid var(--color-warning);
}

.notice-icon {
  font-size: 36rpx;
}

.notice-text {
  flex: 1;
  font-size: var(--font-size-xs);
  color: var(--color-gray-600);
  line-height: var(--line-height-relaxed);
}

.modal-footer {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-gray-100);
  background: var(--color-white);
}

.modal-footer .btn {
  flex: 1;
}

.btn-danger {
  background: var(--color-error-gradient);
  color: var(--color-white);
  box-shadow: 0 4rpx 12rpx rgba(229, 62, 62, 0.3);
}

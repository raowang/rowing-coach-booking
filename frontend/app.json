      },
      {
        "pagePath": "pages/coach-list/coach-list",
        "text": "教练",
        "iconPath": "miniprogram/assets/icons/coach.png",
        "selectedIconPath": "miniprogram/assets/icons/coach-active.png"
      },
      {
        "pagePath": "pages/schedule/schedule",
        "text": "日程",
        "iconPath": "miniprogram/assets/icons/schedule.png",
        "selectedIconPath": "miniprogram/assets/icons/schedule-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "miniprogram/assets/icons/profile.png",
        "selectedIconPath": "miniprogram/assets/icons/profile-active.png"
      }
    ]
  },
  "permission": {
    "scope.userLocation": {
      "desc": "获取您的位置以便推荐最近的赛艇中心"
    }
  },

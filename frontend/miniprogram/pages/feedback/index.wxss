.feedback-header {
  background: #ffffff;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.coach-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.coach-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.coach-detail {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.coach-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.training-date {
  font-size: 26rpx;
  color: #666666;
  margin-top: 4rpx;
}

.rating-row {
  display: flex;
  align-items: center;
}

.rating-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.stars {
  display: flex;
}

.stars image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 8rpx;
}

.section {
  background: #ffffff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.ai-badge {
  width: 36rpx;
  height: 36rpx;
  margin-left: 12rpx;
}

.coach-comment {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.coach-comment text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.ai-suggestions {
  display: flex;
  flex-direction: column;
}

.suggestion-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.suggestion-icon image {
  width: 100%;
  height: 100%;
}

.suggestion-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a5f7a;
}

.suggestion-desc {
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
  line-height: 1.4;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.history-tag {
  background: #fff3e0;
  color: #ff9800;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.action-area {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
}

.btn-book-again,
.btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 0;
}

.btn-book-again {
  background: linear-gradient(135deg, #1a5f7a, #2d8eb4);
  color: #ffffff;
}

.btn-share {
  background: #ffffff;
  color: #1a5f7a;
  border: 2rpx solid #1a5f7a;
}

.next-training-hint {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #e8f4f8;
  margin: 0 24rpx 24rpx;
  border-radius: 12rpx;
}

.next-training-hint image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.next-training-hint text {
  font-size: 26rpx;
  color: #1a5f7a;
}
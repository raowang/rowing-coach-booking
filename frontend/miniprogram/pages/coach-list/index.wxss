.search-bar {
  padding: 24rpx 32rpx;
  background: #ffffff;
}

.search-input {
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.filter-tabs {
  display: flex;
  padding: 0 32rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab.active {
  color: #1a5f7a;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1a5f7a;
  border-radius: 2rpx;
}

.coach-list {
  height: calc(100vh - 300rpx);
  padding: 24rpx;
}

.coach-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.coach-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.coach-avatar image {
  width: 100%;
  height: 100%;
}

.online-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  background: #07c160;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

.coach-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.coach-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.coach-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.coach-rating {
  display: flex;
  align-items: center;
}

.coach-rating image {
  width: 24rpx;
  height: 24rpx;
  margin-right: 4rpx;
}

.coach-rating text {
  font-size: 28rpx;
  color: #ff9800;
}

.coach-tags {
  display: flex;
  flex-wrap: wrap;
  margin: 12rpx 0;
}

.tag {
  background: #e8f4f8;
  color: #1a5f7a;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.coach-style {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.coach-bio {
  font-size: 26rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.ai-recommend {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #ff9800, #ff5722);
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.loading-more,
.no-more,
.empty {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 26rpx;
}

.recommendation-banner {
  position: fixed;
  bottom: 120rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, #1a5f7a, #2d8eb4);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(26, 95, 122, 0.3);
}

.banner-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.banner-content image {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.banner-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 4rpx;
}

.arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}
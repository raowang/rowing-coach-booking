page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #1a5f7a 0%, #2d8eb4 100%);
  color: #ffffff;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #ffffff;
  color: #1a5f7a;
  border: 2rpx solid #1a5f7a;
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}

.text-primary {
  color: #1a5f7a;
}

.text-secondary {
  color: #666666;
}

.text-bold {
  font-weight: 600;
}